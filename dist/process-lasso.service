[Unit]
Description=Process Lasso — Linux process manager (GUI + daemon)
Documentation=https://github.com/franzjeger/process-lasso-linux-rs
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=simple
ExecStart=%h/.local/bin/process-lasso --minimized
Restart=on-failure
RestartSec=5

# Keep the process alive through session bus disconnects
Environment=RUST_LOG=warn

[Install]
WantedBy=graphical-session.target
